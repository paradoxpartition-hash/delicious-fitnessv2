# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# ── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Stripe ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_MONTHLY=price_...
STRIPE_PRICE_ID_ANNUAL=price_...

# ── AI — Translation + Meal Planning ─────────────────────────────────────────
# Primary: Groq (FREE — 14,400 req/day)
# Sign up: https://console.groq.com
GROQ_API_KEY=gsk_...

# Fallback 1: Gemini Flash (FREE — 1,500 req/day)
# Sign up: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# Fallback 2: OpenRouter (FREE tier — 50 req/day, many models)
# Sign up: https://openrouter.ai
OPENROUTER_API_KEY=sk-or-...

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
NEXT_PUBLIC_BUILD_SIGNATURE=DF-PARADOX-SaaS-2026
NEXT_PUBLIC_SYSTEM_DEVELOPER=SaaSolutions SL
NEXT_PUBLIC_SYSTEM_OWNER=Paradox FZCO

# ── Notes ────────────────────────────────────────────────────────────────────
# Translation priority: Groq → Gemini → OpenRouter
# Meal plan generation: Groq (primary), Gemini (fallback)
# You only NEED GROQ_API_KEY to run the full platform.
# GEMINI_API_KEY and OPENROUTER_API_KEY are optional fallbacks.
