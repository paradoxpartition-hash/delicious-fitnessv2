# ─── Supabase (per environment — never share across DEV/TEST/PROD) ─────────────
NEXT_PUBLIC_SUPABASE_URL="http://127.0.0.1:54321"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-local-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-local-service-role-key"

# ─── Free LLM Providers (priority fallback chain) ──────────────────────────────
# 1. Gemini 2.5 Flash — best quality, 1,500 req/day free
#    Sign up: https://ai.google.dev
GEMINI_API_KEY=""

# 2. Groq Llama 3.3 70B — fastest, 14,400 req/day free
#    Sign up: https://console.groq.com
GROQ_API_KEY=""

# 3. OpenRouter (meta-llama/llama-3.3-70b-instruct:free) — fallback
#    Sign up: https://openrouter.ai
OPENROUTER_API_KEY=""

# ─── Translation ───────────────────────────────────────────────────────────────
# DeepL free: 500,000 chars/month — optional, LLM handles it if not set
DEEPL_API_KEY=""

# ─── Stripe (test keys for DEV/TEST, live keys for PROD only) ──────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_CHEF_MONTHLY_PRICE_ID="price_..."
STRIPE_CHEF_ANNUAL_PRICE_ID="price_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ─── Auth ──────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
WEB_URL="http://localhost:3000"

# ─── Cron security ─────────────────────────────────────────────────────────────
